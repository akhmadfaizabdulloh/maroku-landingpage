<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Maroku.id - Custom Cake & Hampers Pasuruan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com" rel="stylesheet">
    <style>
        @import url('https://fonts.googleapis.com');
        body { font-family: 'Quicksand', sans-serif; }
        .font-handwriting { font-family: 'Sacramento', cursive; }
    </style>
</head>
<body class="bg-rose-50">

    <!-- Navbar -->
    <nav class="p-6 flex justify-between items-center bg-white shadow-sm sticky top-0 z-50">
        <h1 class="text-2xl font-bold text-rose-500">Maroku<span class="text-gray-700">.id</span></h1>
        <div class="space-x-6 hidden md:block">
            <a href="#home" class="hover:text-rose-400">Home</a>
            <a href="#menu" class="hover:text-rose-400">Menu</a>
            <a href="#lokasi" class="hover:text-rose-400">Lokasi</a>
            <a href="https://wa.me" class="bg-rose-500 text-white px-5 py-2 rounded-full hover:bg-rose-600 transition">Order Sekarang</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="py-20 px-10 text-center bg-[url('https://images.unsplash.com')] bg-cover bg-center relative">
        <div class="absolute inset-0 bg-white/70"></div>
        <div class="relative z-10">
            <h2 class="text-5xl md:text-6xl font-handwriting text-rose-600 mb-4">Sajian Manis di Setiap Momen</h2>
            <p class="text-gray-600 max-w-lg mx-auto mb-8">Custom Cake, Korean Bento, & Hampers Cantik Premium di Kota Pasuruan.</p>
            <a href="#menu" class="bg-rose-500 text-white px-8 py-3 rounded-full shadow-lg hover:bg-rose-600">Lihat Katalog</a>
        </div>
    </section>

    <!-- Menu Showcase -->
    <section id="menu" class="py-16 container mx-auto">
        <h3 class="text-3xl font-bold text-center mb-12 text-gray-800">Menu Favorit</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 px-6">
            <!-- Bento Cake -->
            <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:scale-105 transition">
                <img src="https://images.unsplash.com" alt="Bento Cake" class="h-64 w-full object-cover">
                <div class="p-6">
                    <h4 class="font-bold text-xl mb-2">Korean Bento Cake</h4>
                    <p class="text-gray-500 text-sm mb-4">Kue mini diameter 10cm dengan desain kustom sesukamu.</p>
                    <span class="text-rose-500 font-bold">Mulai Rp 45k</span>
                </div>
            </div>
            <!-- Chiffon Cake -->
            <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:scale-105 transition">
                <img src="https://images.unsplash.com" alt="Hampers" class="h-64 w-full object-cover">
                <div class="p-6">
                    <h4 class="font-bold text-xl mb-2">Premium Hampers</h4>
                    <p class="text-gray-500 text-sm mb-4">Paket cantik berisi kue kering & cookies untuk bingkisan spesial.</p>
                    <span class="text-rose-500 font-bold">Hubungi Admin</span>
                </div>
            </div>
            <!-- Custom Cake -->
            <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:scale-105 transition">
                <img src="https://images.unsplash.com" alt="Custom Cake" class="h-64 w-full object-cover">
                <div class="p-6">
                    <h4 class="font-bold text-xl mb-2">Custom Tart</h4>
                    <p class="text-gray-500 text-sm mb-4">Kue tart besar untuk acara ulang tahun dan anniversary.</p>
                    <span class="text-rose-500 font-bold">Mulai Rp 150k</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Info Section (Lokasi) -->
    <section id="lokasi" class="bg-rose-100 py-16 px-6">
        <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-10">
            <div class="flex-1">
                <h3 class="text-3xl font-bold mb-4">Mampir ke Studio Kami</h3>
                <p class="text-gray-700 mb-4 italic italic">"Bikin momen makin manis di Randusari!"</p>
                <p class="text-gray-600 mb-6">
                    <i class="fas fa-map-marker-alt text-rose-500 mr-2"></i> Jl. Gatot Subroto No. 7, Randusari, Kota Pasuruan.
                </p>
                <div class="flex gap-4">
                    <a href="https://www.instagram.com" class="text-rose-500 text-2xl hover:text-rose-700"><i class="fab fa-instagram"></i></a>
                    <a href="https://wa.me" class="text-rose-500 text-2xl hover:text-rose-700"><i class="fab fa-whatsapp"></i></a>
                </div>
            </div>
            <div class="flex-1 w-full h-64 bg-gray-300 rounded-lg shadow-inner flex items-center justify-center">
                <!-- Placeholder untuk Google Maps -->
                <p class="text-gray-500 px-4 text-center">Gunakan [Google Maps](https://www.google.com) untuk menyematkan lokasi tepatnya di sini.</p>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-8 text-center text-gray-500 text-sm">
        <p>&copy; 2026 Maroku.id Pasuruan. Crafted with Love.</p>
    </footer>

</body>
</html>
